import pandas as pd

# 1. Loading the data using pandas

df = pd.read_csv("heart1.csv")

# 2. Inspect Data: we use info function that shows data types and if there are missing values
print("--- Data Info ---")
df.info()

# Describing the data and displaying it
display(df.describe())

# 3. Renaming the columns
df.rename(columns={
    "index" : "ID",
    "cp" : "chest_pain_type",
    "trestbps" : "resting_blood_pressure",
    "chol" : "cholesterol",
    "fbs" : "fasting_blood_sugar",
    "restecg" : "resting_ecg_result",
    "thalach" : "max_heart_rate",
    "exang" : "exercise_angina",
    "ca" : "num_major_vessels",
    "thal": "thalassemia"}, inplace=True)

# 4. Handle Missing Values
# the count of missing values which is a null value
print("\n--- Missing Values Count ---")
print(df.isnull().sum())

# If any numeric line is empty we fill it with the median cause its the safest guess
df = df.fillna(df.median(numeric_only=True))

# 5. Export Cleaned Dataset (Deliverable)
df.to_csv("cleaned_heart_data.csv", index=False)
display(df.head())

